# =============================================================================
# Configuración del despliegue del entorno de test (fs-test-env).
#
# init-project.sh genera <proyecto>/.fs-test-env.env a partir de este ejemplo.
# NO edites este fichero en el submódulo; edita el .fs-test-env.env del proyecto.
# Todo lo que no se defina aquí cae en defaults genéricos dentro de los scripts.
# =============================================================================

# --- Estructura del proyecto FacturaScripts ---
# Carpeta del core dentro del proyecto: 'src' (como Mesa_FS) o '.' (FS estándar).
FS_CORE_DIR="src"
# Ruta absoluta del proyecto. Debe ser IDÉNTICA en host y contenedor (se monta así).
TESTENV_REPO_PATH="/ruta/absoluta/al/proyecto"
# Directorio del core de pruebas (vacío = <proyecto>/test-env/facturascripts).
TESTENV_DIR=""

# --- Provisión (base de datos y core de pruebas) ---
TEST_DB="fs_test"
CORE_REPO="https://github.com/NeoRazorX/facturascripts.git"
# Rama o TAG del core. Vacío = el tag de la versión instalada (v<Kernel::version()>),
# con fallback a 'master'. Las versiones de FacturaScripts son tags con prefijo 'v'.
CORE_BRANCH=""
# Lista de plugins a construir en el warm-up (vacío = todos los enlazados).
ENABLE_LIST=""
FS_LANG="es_ES"
FS_TIMEZONE="UTC"

# --- Runner web ---
TEST_WEB_TITLE="Tests de plugins"
# Solo informativo (mensajes de ayuda); p.ej. https://test.miproyecto.example
TEST_WEB_URL=""

# --- Contenedor / red / proxy (para renderizar el servicio compose y el vhost) ---
# Motor de contenedores: 'podman' (usa userns keep-id + sysctl de puertos) o 'docker'.
CONTAINER_ENGINE="podman"
TESTENV_SERVICE="fs-testenv"
TESTENV_CONTAINER="fs-testenv"
TESTENV_HOST="test.localhost"
TESTENV_IMAGE="localhost/php_devel:8.4"
TESTENV_NETWORK="default"
TESTENV_TRAEFIK_ROUTER="fs-testenv"
TESTENV_RUN_USER="www-data"
# Servicio de BD de tu compose (solo para el depends_on comentado de la plantilla).
TESTENV_DB_SERVICE="db"
